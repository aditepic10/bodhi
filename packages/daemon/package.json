{
  "name": "@bodhi/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "bodhi": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/daemon.ts",
    "cli": "bun run src/cli.ts",
    "build": "bun build src/daemon.ts --outdir dist --target bun",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.58",
    "@ai-sdk/openai": "3.0.41",
    "@bodhi/types": "workspace:*",
    "@secretlint/core": "11.3.1",
    "@secretlint/secretlint-rule-preset-recommend": "11.3.1",
    "ai": "6.0.116",
    "drizzle-orm": "0.45.1",
    "hono": "4.12.7",
    "nanoid": "5.1.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "drizzle-kit": "0.31.9",
    "typescript": "catalog:"
  }
}
